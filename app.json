{
  "expo": {
    "name": "CampusTransit",
    "slug": "CampusTransit",
    "scheme": "acme",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./src/assets/app-icon.png",
    "android": {
      "package": "com.expert.potato",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/app-icon.png",
        "backgroundColor": "#0B2E13"
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://n"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {
        "origin": "https://n"
      }
    }
  }
}
